<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Programa de Recompensas</title>
  <meta name="description" content="Sumá puntos, subí de nivel y desbloqueá beneficios." />

  <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🎰</text></svg>">
  <!-- reutiliza tu diseño -->
  <link rel="stylesheet" href="styles.css" />

  <style>
    /* ajustes solo para esta landing */
    .heroPromo{
      margin-top: 18px;
      padding: 22px;
      border-radius: 20px;
      border:1px solid rgba(255,255,255,.10);
      background: linear-gradient(135deg, rgba(109,40,217,.14), rgba(255,255,255,.03));
      box-shadow: 0 18px 60px rgba(0,0,0,.55);
    }
    .heroPromo h1{ margin: 6px 0 8px; font-size: 42px; letter-spacing:-.03em; }
    .heroPromo p{ margin: 0; }
    .promoGrid{
      display:grid;
      grid-template-columns: 1fr;
      gap: 12px;
      margin-top: 14px;
    }
    .kpi{
      padding: 14px;
      border-radius: 16px;
      border:1px solid rgba(255,255,255,.10);
      background: rgba(0,0,0,.16);
    }
    .kpi .t{ color: rgba(255,255,255,.70); font-size: 12px; letter-spacing:.10em; text-transform:uppercase; }
    .kpi .v{ font-weight: 1000; margin-top: 6px; font-size: 18px; }
    .ctaRow{ display:flex; gap:10px; flex-wrap:wrap; margin-top: 14px; }
    .btnLink{ text-decoration:none; }
    @media (min-width: 900px){
      .promoGrid{ grid-template-columns: 1fr 1fr 1fr; }
    }
  </style>
</head>

<body>
  <header class="hero">
    <div class="container">
      <div class="heroPromo">
        <div class="pill">✨ Nuevo sistema de beneficios</div>
        <h1>Subí de nivel y ganá <span class="grad">más beneficios</span></h1>
        <p class="lead">
          Sumás puntos con cada carga, subís de categoría y desbloqueás beneficios exclusivos.
          <strong>Se cuentan los últimos 30 días.</strong>
        </p>

        <div class="promoGrid">
          <div class="kpi">
            <div class="t">Regla</div>
            <div class="v">$1.000 = 1 punto</div>
          </div>
          <div class="kpi">
            <div class="t">Niveles</div>
            <div class="v">Bronce → Leyenda</div>
          </div>
          <div class="kpi">
            <div class="t">Canje</div>
            <div class="v">Puntos → Créditos</div>
          </div>
        </div>

        <div class="ctaRow">
          <a class="btn btn--primary btnLink" href="/#mis-puntos">Ver mis puntos</a>
          <a class="btn btn--ghost btnLink" href="/#niveles">Ver niveles</a>
        </div>

        <p class="muted small" style="margin-top:10px;">
          * Los créditos obtenidos por canje son <strong>no extraíbles</strong> y de uso interno.
        </p>
      </div>
    </div>
  </header>

  <main class="container">

    <section class="section">
      <div class="section__head">
        <h2>¿Cómo funciona?</h2>
        <p class="muted">Rápido y simple.</p>
      </div>

      <div class="cards2">
        <div class="card">
          <h3>Sumá puntos</h3>
          <p class="muted">Cada carga suma puntos automáticamente.</p>
          <p><strong>$1.000 = 1 punto</strong></p>
        </div>
        <div class="card">
          <h3>Subí de nivel</h3>
          <p class="muted">Más nivel = más beneficios.</p>
          <p><strong>Progreso sobre últimos 30 días</strong></p>
        </div>
      </div>
    </section>

    <section class="section" id="niveles">
      <div class="section__head">
        <h2>Niveles destacados</h2>
        <p class="muted">Algunos beneficios por nivel.</p>
      </div>

      <div class="levels">
        <div class="level level--gold">
          <div class="level__top">
            <div class="level__ic">🥇</div>
            <div>
              <div class="level__name">Oro</div>
              <div class="muted small">150 a 399 puntos</div>
            </div>
            <div class="pct">+20%</div>
          </div>
        </div>

        <div class="level level--diamond">
          <div class="level__top">
            <div class="level__ic">💎</div>
            <div>
              <div class="level__name">Diamante</div>
              <div class="muted small">400 a 999 puntos</div>
            </div>
            <div class="pct">+35%</div>
          </div>
          <div class="level__extra muted small">
            + beneficio semanal exclusivo • + jornadas con puntos potenciados
          </div>
        </div>

        <div class="level level--legend">
          <div class="ribbon">Más buscado</div>
          <div class="level__top">
            <div class="level__ic">👑</div>
            <div>
              <div class="level__name">Leyenda</div>
              <div class="muted small">1000+ puntos</div>
            </div>
            <div class="pct">+50%</div>
          </div>
          <div class="level__extra muted small">
            + semanal premium • + mensual especial • + puntos potenciados • + permanencia
          </div>
        </div>
      </div>

      <div class="ctaRow" style="margin-top:14px;">
        <a class="btn btn--primary btnLink" href="/#mis-puntos">Entrar y consultar</a>
        <a class="btn btn--ghost btnLink" href="/">Ir al programa</a>
      </div>
    </section>

  </main>

  <footer class="footer">
    <div class="container footer__inner">
      <div class="muted small">Programa sujeto a cambios. Consultá soporte para más info.</div>
      <div class="muted small">© Programa de Recompensas</div>
    </div>
  </footer>
</body>
</html>
